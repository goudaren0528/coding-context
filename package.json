{
  "name": "ctx",
  "version": "0.1.0",
  "description": "AI Workspace Runtime — persistent project memory for Claude Code and OpenCode",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ctx": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "claude",
    "opencode",
    "ai",
    "context",
    "memory",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "nanoid": "^5.1.0",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  }
}
