{
  "name": "ctx",
  "version": "0.3.0",
  "description": "Local-first CLI runtime that adds persistent project memory to Claude Code and OpenCode.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ctx": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@10",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goudaren0528/coding-context.git"
  },
  "homepage": "https://github.com/goudaren0528/coding-context#readme",
  "bugs": {
    "url": "https://github.com/goudaren0528/coding-context/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "anthropic",
    "claude-code",
    "opencode",
    "cli",
    "developer-tools",
    "local-first",
    "project-memory",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "nanoid": "^5.1.0",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  }
}
